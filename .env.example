# Public base URL used by metadata routes (sitemap/robots)
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API client base URL fallback chain:
# 1) NEXT_PUBLIC_API_URL
# 2) NEXT_PUBLIC_API_URL_PROD (if NEXT_PUBLIC_RUN_MODE=production)
# 3) NEXT_PUBLIC_API_URL_DEV
NEXT_PUBLIC_RUN_MODE=development
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_URL_DEV=http://localhost:3000/api
NEXT_PUBLIC_API_URL_PROD=https://api.example.com